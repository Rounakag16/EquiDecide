# Optional Phase-2 provider setup

# Provider priority:
# 1) Local Ollama (free, no API key)
# 2) Gemini API (if GEMINI_API_KEY provided)
# 3) Deterministic KB fallback

# Local Ollama
OLLAMA_MODEL=llama3.2

# Optional Gemini (free tier available)
# GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-1.5-flash

